{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "oekakibbsstyledouga",
  "version": "0.1.0",
  "identifier": "com.juninaba.oekakibbsstyledouga",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$TMP/**",
          "/tmp/**",
          "/private/tmp/**",
          "/var/folders/**"
        ]
      }
    },
    "windows": [
      {
        "title": "oekakibbsstyledouga",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false,
    "icon": [],
    "targets": "all"
  }
}
